# ─────────────────────────────────────────────
# XoPOS  –  Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────

# ── Store branding ────────────────────────────
VITE_STORE_NAME=XoPOS
VITE_STORE_TAGLINE=Point of Sale

# ── UPI payment ───────────────────────────────
# Your merchant UPI VPA (e.g. mystore@paytm)
VITE_UPI_ID=yourshop@upi

# ── Backend API (optional) ────────────────────
# Base URL of your Node/Express billing backend
VITE_API_BASE_URL=http://localhost:5000/api

# ── Security – PIN hashes (SHA-256, hex) ─────
# Default cashier PIN: 1234  → hash below
# Generate a new hash: https://emn178.github.io/online-tools/sha256.html
VITE_CASHIER_PIN_HASH=03ac674216f3e15c761ee1a5e255f067953623c8b388b4459e13f978d7c846f4

# Default manager PIN: 9999  → hash below
VITE_MANAGER_PIN_HASH=1b4f0e9851971998e732078544c96b36c3d01cedf7caa332359d6f1d83567014

# ── GST configuration ─────────────────────────
VITE_GST_RATE=0.05
