NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/xopos

# Redis (optional – for pub/sub. If not installed, events degrade gracefully)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS – comma separated list of allowed origins
CORS_ORIGIN=http://localhost:5173

# Printer (optional backend relay)
PRINTER_BAUD_RATE=9600
